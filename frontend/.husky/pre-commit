#!/usr/bin/env sh

# Проверяем, есть ли измененные файлы (staged) в папке frontend
STAGED_FRONTEND_FILES=$(git diff --cached --name-only -- "frontend/")

# Если изменений в frontend нет — пропускаем проверки
if [ -z "$STAGED_FRONTEND_FILES" ]; then
  echo " [Husky] Изменения не затрагивают frontend. Пропускаем."
  exit 0
fi

# Переходим в папку frontend
FRONTEND_DIR="$(git rev-parse --show-toplevel)/frontend"
cd "$FRONTEND_DIR" || exit 1

echo " [Husky] Запуск проверок для frontend..."

# 1. Вызываем локальный lint-staged напрямую (обходит баг с npx)
./node_modules/.bin/lint-staged || npx.cmd lint-staged || exit 1

# 2. Проверка типов
npm run type-check || npm.cmd run type-check || exit 1
