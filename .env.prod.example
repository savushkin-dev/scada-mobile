# Copy to .env.prod.local and adjust values for your environment.
# This file contains only non-secret transport/config examples.

# ── Порты ───────────────────────────────────────────────────────────────────
SCADA_MOBILE_BACKEND_PORT=9999
SCADA_MOBILE_FRONTEND_PORT=9998

# ── PostgreSQL ──────────────────────────────────────────────────────────────
SCADA_MOBILE_POSTGRES_PORT=5432
SCADA_MOBILE_POSTGRES_DB=scada_mobile
SCADA_MOBILE_POSTGRES_USER=scada_user
SCADA_MOBILE_DATABASE_PASSWORD=

# ── JWT secrets ────────────────────────
SCADA_MOBILE_JWT_ACCESS_SECRET=
SCADA_MOBILE_JWT_REFRESH_SECRET=

# ── CORS ────────────────────────────────────────────────────────────────────
SCADA_MOBILE_CORS_POLICY_ALLOWED_ORIGINS=http://999.9.9.9:9998

# The initial admin account is created automatically by the backend when no ADMIN user exists.
