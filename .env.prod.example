# Copy to .env.prod.local and adjust values for your environment.
# This file contains only non-secret transport/config examples.

BACKEND_PORT=9999
FRONTEND_PORT=9998
# Exact browser origin(s) of the frontend.
# If users open the UI as http://999.9.9.9:9999, specify http://999.9.9.9:9999 here.
# Multiple origins are allowed as a comma-separated list without spaces.
CORS_POLICY_ALLOWED_ORIGINS=http://999.9.9.9:9998

